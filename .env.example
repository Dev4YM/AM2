# Required for NextAuth session signing (generate: openssl rand -base64 32)
AUTH_SECRET=

# Optional: OpenAI for Smart Reviews, Smart Emails, and AI Assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SQLite database path (default: ./data/am2.db)
DATABASE_PATH=

# Public app URL (for auth callbacks in production)
NEXTAUTH_URL=http://localhost:3000
