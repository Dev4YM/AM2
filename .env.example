# Copy to repo root as `.env` (not under apps/web)
# cp .env.example .env
# Web dev symlinks apps/web/.env -> ../../.env on first run (npm run prepare-env)
# API loads via Nest ConfigModule envFilePath: ../../.env

# ─── Web (@am2/web) ───────────────────────────────────────────────────────────

# Required for NextAuth session signing (generate: openssl rand -base64 32)
AUTH_SECRET=

# Google Maps + Places (Business Finder live search)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: OpenAI for Smart Reviews, Smart Emails, and AI Assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Shared CRM SQLite (web + api) — default resolves to apps/web/data/am2.db
DATABASE_PATH=apps/web/data/am2.db

# Public app URL (auth callbacks in production)
NEXTAUTH_URL=http://localhost:3000

# NestJS API (search proxy + qualified data enrich)
NEXT_PUBLIC_AM2_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side proxy from Next /api/search → Nest (defaults to AM2_API_URL or above)
AM2_API_URL=http://localhost:4000
# Shared secret between Next BFF and Nest (generate: openssl rand -hex 32)
AM2_INTERNAL_API_KEY=

# Optional: Hunter.io domain search for enriched emails
HUNTER_API_KEY=

# ─── API (@am2/api) ──────────────────────────────────────────────────────────

# HTTP port for NestJS API (default 4000)
PORT=4000

# Comma-separated origins for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Google Places (same keys as web; used by /places and /search)
# GOOGLE_MAPS_API_KEY=
# GOOGLE_PLACES_API_KEY=

# OpenAI (AI center: summaries, smart sales, smart emails)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
